// MainWindow.idl - WinRT 接口定义
namespace MoeKoeGUI
{
    [default_interface]
    runtimeclass MainWindow : Microsoft.UI.Xaml.Window
    {
        MainWindow();
        
        String SongTitle { get; set; };
        String SongArtist { get; set; };
        String CurrentLyric { get; set; };
        Double Progress { get; set; };
        String TimeText { get; set; };
        
        event Microsoft.UI.Xaml.Data.PropertyChangedEventHandler PropertyChanged;
        
        void UpdateSongInfo(String title, String artist);
        void UpdateLyric(String lyric);
        void UpdateProgress(Double current, Double total);
    }
}
